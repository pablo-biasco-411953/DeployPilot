<Window x:Class="DeployPilot.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WindowTitle}" Height="720" Width="1040"
        MinHeight="620" MinWidth="900" Background="#0E1110"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1A1F1D" />
            <Setter Property="BorderBrush" Value="#29312D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Width" Value="246" />
            <Setter Property="MinHeight" Value="242" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#55D494" />
            <Setter Property="Foreground" Value="#07120D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1F2522" />
            <Setter Property="Foreground" Value="#D7E2DD" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#131716" BorderBrush="#242B27" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="10" Background="#55D494">
                        <TextBlock Text="D" Foreground="#07120D" FontWeight="Black" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="DeployPilot" Foreground="White" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="Launcher" Foreground="#91A099" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,34,0,0">
                    <Button Content="Modules" Style="{StaticResource PrimaryButton}" />
                    <Button Content="History" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" />
                    <Button Content="Settings" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" />
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="API endpoint" Foreground="#55D494" FontWeight="SemiBold" />
                    <TextBox x:Name="ApiEndpointBox" Margin="0,8,0,10" Height="34" Background="#0B0E0D" Foreground="#D7E2DD" BorderBrush="#29312D" />
                    <TextBlock Text="Artifact endpoint" Foreground="#55D494" FontWeight="SemiBold" />
                    <TextBox x:Name="ArtifactEndpointBox" Margin="0,8,0,10" Height="34" Background="#0B0E0D" Foreground="#D7E2DD" BorderBrush="#29312D" />
                    <Button Content="Refresh" Click="RefreshButton_Click" Style="{StaticResource PrimaryButton}" />
                    <Button Content="Seed demo data" Click="SeedDemoButton_Click" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" />
                    <ComboBox x:Name="LanguageSelector" Margin="0,14,0,0" Height="34" SelectionChanged="LanguageSelector_SelectionChanged">
                        <ComboBoxItem Content="English" Tag="en-US" IsSelected="True" />
                        <ComboBoxItem Content="Español" Tag="es-AR" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock Text="{DynamicResource HeroTitle}" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="{DynamicResource HeroSubtitle}" Foreground="#8F9A96" Margin="0,8,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#55D494" Margin="0,18,0,0" FontWeight="SemiBold" />

                <ItemsControl ItemsSource="{Binding Modules}" Margin="0,26,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                    <TextBlock Foreground="#8F9A96" Margin="0,4,0,0">
                                        <Run Text="v" />
                                        <Run Text="{Binding CurrentVersion}" />
                                        <Run Text=" -> v" />
                                        <Run Text="{Binding LatestVersion}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Status}" Foreground="#55D494" Margin="0,18,0,0" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Changelog}" Foreground="#D7E2DD" TextWrapping="Wrap" Margin="0,8,0,18" Height="64" />
                                    <ProgressBar Value="{Binding Progress}" Height="8" Foreground="#55D494" Background="#0B0E0D" />
                                    <TextBlock Text="{Binding SpeedLabel}" Foreground="#55D494" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ExecutableName}" Foreground="#8F9A96" Margin="0,8,0,18" />
                                    <Button Content="{Binding ActionLabel}" Click="ModuleActionButton_Click" Tag="{Binding}" Style="{StaticResource PrimaryButton}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
