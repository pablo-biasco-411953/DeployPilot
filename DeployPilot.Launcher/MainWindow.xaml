<Window x:Class="DeployPilot.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WindowTitle}" Height="720" Width="1040"
        MinHeight="620" MinWidth="900" Background="#0E1110">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1A1F1D" />
            <Setter Property="BorderBrush" Value="#29312D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,18,18" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#55D494" />
            <Setter Property="Foreground" Value="#07120D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#131716" BorderBrush="#242B27" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="10" Background="#55D494">
                        <TextBlock Text="D" Foreground="#07120D" FontWeight="Black" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="DeployPilot" Foreground="White" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="Launcher" Foreground="#91A099" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,34,0,0">
                    <Button Content="Modules" Style="{StaticResource PrimaryButton}" />
                    <Button Content="History" Margin="0,10,0,0" Height="40" Background="#1F2522" Foreground="#D7E2DD" BorderThickness="0" />
                    <Button Content="Settings" Margin="0,10,0,0" Height="40" Background="#1F2522" Foreground="#D7E2DD" BorderThickness="0" />
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="First launch" Foreground="#55D494" FontWeight="SemiBold" />
                    <TextBlock Text="API endpoint, artifact source and language can be configured here." Foreground="#8F9A96" TextWrapping="Wrap" Margin="0,6,0,14" />
                    <ComboBox x:Name="LanguageSelector" Height="34" SelectionChanged="LanguageSelector_SelectionChanged">
                        <ComboBoxItem Content="English" Tag="en-US" IsSelected="True" />
                        <ComboBoxItem Content="Español" Tag="es-AR" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock Text="{DynamicResource HeroTitle}" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="{DynamicResource HeroSubtitle}" Foreground="#8F9A96" Margin="0,8,0,0" />

                <UniformGrid Columns="3" Margin="0,26,0,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Inventory Desktop" Foreground="White" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="v1.2.0 -> v1.3.0" Foreground="#55D494" Margin="0,4,0,0" />
                            <TextBlock Text="Update available" Foreground="#8F9A96" Margin="0,18,0,0" />
                            <TextBlock Text="Improved build manifests, rollback and integrity validation." Foreground="#D7E2DD" TextWrapping="Wrap" Margin="0,8,0,18" />
                            <ProgressBar Value="64" Height="8" Foreground="#55D494" Background="#0B0E0D" />
                            <TextBlock Text="Downloading at 4.8 MB/s" Foreground="#8F9A96" Margin="0,8,0,18" />
                            <Button Content="Update" Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Billing Console" Foreground="White" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="v2.0.4" Foreground="#8F9A96" Margin="0,4,0,0" />
                            <TextBlock Text="Everything is up to date" Foreground="#55D494" Margin="0,18,0,0" />
                            <TextBlock Text="Integrity verified against the published artifact manifest." Foreground="#D7E2DD" TextWrapping="Wrap" Margin="0,8,0,18" />
                            <Button Content="Open" Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Lab Reports" Foreground="White" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="v0.9.8" Foreground="#8F9A96" Margin="0,4,0,0" />
                            <TextBlock Text="Rollback available" Foreground="#F4BE5E" Margin="0,18,0,0" />
                            <TextBlock Text="A previous version can be restored from the version picker." Foreground="#D7E2DD" TextWrapping="Wrap" Margin="0,8,0,18" />
                            <Button Content="Versions" Height="40" Background="#1F2522" Foreground="#D7E2DD" BorderThickness="0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
